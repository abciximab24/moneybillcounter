rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Trips collection - any authenticated user can access
    // Security is enforced at query level (app queries memberEmails array)
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
    }
    
    // Expenses collection - any authenticated user can access
    match /expenses/{expenseId} {
      allow read, write: if request.auth != null;
    }
    
    // Settlements collection - any authenticated user can access
    match /settlements/{settlementId} {
      allow read, write: if request.auth != null;
    }
  }
}